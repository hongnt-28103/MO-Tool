// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model UserToken {
  id                String    @id @default(cuid())
  email             String    @unique
  refreshTokenEnc   String
  accessToken       String
  accessTokenExpiry DateTime
  publisherId       String?
  publisherName     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  email       String
  action      String
  publisherId String
  payload     String   // JSON string (SQLite workaround)
  result      String   // JSON string
  statusCode  Int
  createdAt   DateTime @default(now())
}

model App {
  id        String   @id @default(cuid())
  email     String
  name      String
  platform  String   // "ANDROID" | "IOS"
  isLive    Boolean  @default(false)
  storeUrl  String?
  bundleId  String?

  // AdMob
  admobPublisherId String?
  admobAppId       String?
  admobStatus      String   @default("none") // none | ok | error
  admobError       String?

  // Pangle
  pangleAppId      String?
  pangleCategoryCode Int?
  pangleStatus     String   @default("none") // none | ok | verifying | error
  pangleError      String?

  // Liftoff
  liftoffAppId     String?
  liftoffStatus    String   @default("none") // none | ok | error
  liftoffError     String?
  liftoffCategory  String?
  liftoffCoppa     Boolean  @default(true)

  // Mintegral
  mintegralAppId        String?
  mintegralAppKey       String?
  mintegralStatus       String   @default("none") // none | ok | error
  mintegralError        String?
  mintegralAndroidStore String?
  mintegralStoreName    String?
  mintegralPreviewLink  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adUnits   AdUnit[]
}

model AdUnit {
  id              String   @id @default(cuid())
  appId           String
  app             App      @relation(fields: [appId], references: [id])
  name            String
  format          String   // INTERSTITIAL, REWARDED, BANNER, NATIVE, APP_OPEN
  tier            String   @default("ap") // high, med, ap (all-price)
  admobAdUnitId   String?
  admobStatus     String   @default("none")
  admobError      String?
  createdAt       DateTime @default(now())

  placements      AdUnitPlacement[]
}

model AdUnitPlacement {
  id            String   @id @default(cuid())
  adUnitId      String
  adUnit        AdUnit   @relation(fields: [adUnitId], references: [id])
  platform      String   // pangle, liftoff, mintegral
  placementId   String?
  placementName String?
  status        String   @default("none") // none, ok, error
  error         String?
  createdAt     DateTime @default(now())
}
